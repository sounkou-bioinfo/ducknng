# name: test/sql/ducknng_ws_transports.test
# group: [ducknng]

require ducknng

query I
SELECT CASE
  WHEN ducknng_start_server('ws_rpc', 'ws://127.0.0.1:45462/_ducknng', 1, 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

query II
SELECT ok, position('"name":"manifest"' IN manifest) > 0
FROM ducknng_get_rpc_manifest('ws://127.0.0.1:45462/_ducknng', 0::UBIGINT)
----
1	1

query I
SELECT ducknng_open_socket('req')
----
1

query I
SELECT ducknng_dial_socket(1, 'ws://127.0.0.1:45462/_ducknng', 1000, 0::UBIGINT)
----
1

query II
SELECT ok, substr(hex(payload), 1, 28) = '0102040000000800000000000000'
FROM ducknng_request_socket(1::UBIGINT, from_hex('01000000000000000000000000000000000000000000'), 1000)
----
1	1

query I
SELECT ducknng_close_socket(1)
----
1

query I
SELECT CASE WHEN ducknng_stop_server('ws_rpc') THEN 1 ELSE 0 END
----
1

statement error
SELECT ducknng_start_server('bad_wss', 'wss://127.0.0.1:45463/_ducknng', 1, 134217728, 300000, 0::UBIGINT)
----
ducknng: wss listeners require TLS configuration

query I
SELECT ducknng_self_signed_tls_config('127.0.0.1', 365, 0) > 0
----
1

query I
SELECT CASE
  WHEN ducknng_start_server('wss_rpc', 'wss://127.0.0.1:45463/_ducknng', 1, 134217728, 300000, 1::UBIGINT)
  THEN 1 ELSE 0 END
----
1

query II
SELECT ok, position('"name":"manifest"' IN manifest) > 0
FROM ducknng_get_rpc_manifest('wss://127.0.0.1:45463/_ducknng', 1::UBIGINT)
----
1	1

query I
SELECT ducknng_open_socket('req')
----
2

query I
SELECT ducknng_dial_socket(2, 'wss://127.0.0.1:45463/_ducknng', 1000, 1::UBIGINT)
----
1

query II
SELECT ok, substr(hex(payload), 1, 28) = '0102040000000800000000000000'
FROM ducknng_request_socket(2::UBIGINT, from_hex('01000000000000000000000000000000000000000000'), 1000)
----
1	1

query I
SELECT ducknng_close_socket(2)
----
1

query I
SELECT CASE WHEN ducknng_stop_server('wss_rpc') THEN 1 ELSE 0 END
----
1

query I
SELECT ducknng_drop_tls_config(1)
----
1
