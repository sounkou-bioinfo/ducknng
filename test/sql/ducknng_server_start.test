# name: test/sql/ducknng_server_start.test
# group: [ducknng]

require ducknng

query I
SELECT CASE
  WHEN ducknng_server_start('sql0', 'ipc:///tmp/ducknng_phase1_sql0.ipc', 1, 134217728, 300000, NULL, NULL, NULL)
  THEN 1 ELSE 0 END
----
1

query TTIII
SELECT name, listen, contexts, running, sessions
FROM ducknng_servers()
----
sql0	ipc:///tmp/ducknng_phase1_sql0.ipc	1	true	0

query I
SELECT CASE WHEN ducknng_server_stop('sql0') THEN 1 ELSE 0 END
----
1
