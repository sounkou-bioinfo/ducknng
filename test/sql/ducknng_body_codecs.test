# name: test/sql/ducknng_body_codecs.test
# group: [ducknng]

require ducknng

query I
SELECT count(*) FROM ducknng_list_codecs()
----
8

query IT
SELECT a, b
FROM ducknng_parse_body('[{"a":1,"b":"x"},{"a":2,"b":"y"}]'::BLOB, 'application/json; charset=utf-8')
ORDER BY a
----
1	x
2	y

query T
SELECT hex(body)
FROM ducknng_parse_body(
  (concat('a,b', chr(10), '1,x', chr(10), '2,y', chr(10)))::BLOB,
  'text/csv'
)
----
612C620A312C780A322C790A

query T
SELECT body_text
FROM ducknng_parse_body('hello from text'::BLOB, 'text/plain; charset=utf-8')
----
hello from text

query T
SELECT hex(body)
FROM ducknng_parse_body(from_hex('000102'), 'application/octet-stream')
----
000102

query I
SELECT CASE
  WHEN ducknng_start_server('codec_rpc', 'ipc:///tmp/ducknng_body_codecs.ipc', 1, 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

query I
SELECT CASE WHEN ducknng_register_exec_method() THEN 1 ELSE 0 END
----
1

statement error
SELECT *
FROM ducknng_query_rpc(
  'ipc:///tmp/ducknng_body_codecs.ipc',
  'SELECT * FROM ducknng_parse_body(''[{"a":3,"b":"z"}]''::BLOB, ''application/json'')',
  0::UBIGINT
)
----
ducknng: DuckDB-reader body codecs cannot run inside service-owned SQL yet

query I
SELECT CASE WHEN ducknng_stop_server('codec_rpc') THEN 1 ELSE 0 END
----
1

query I
SELECT CASE
  WHEN ducknng_start_http_server('codec_http', 'http://127.0.0.1:45464/_ducknng', 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

query IT
SELECT ok, type_name
FROM ducknng_ncurl_table(
  'http://127.0.0.1:45464/_ducknng',
  'POST',
  '[{"name":"Content-Type","value":"application/vnd.ducknng.frame"}]',
  from_hex('01000000000000000000000000000000000000000000'),
  2000,
  0::UBIGINT
)
----
1	result

query IT
SELECT ok, type_name
FROM ducknng_ncurl_table(
  'http://127.0.0.1:45464/_ducknng',
  'POST',
  '[{"name":"Content-Type","value":"Application/Vnd.Ducknng.Frame; charset=binary"}]',
  from_hex('01000000000000000000000000000000000000000000'),
  2000,
  0::UBIGINT
)
----
1	result

query I
SELECT CASE WHEN ducknng_stop_server('codec_http') THEN 1 ELSE 0 END
----
1
