# name: test/sql/ducknng_negative_paths.test
# group: [ducknng]

require ducknng

statement error
SELECT ducknng_stop_server('missing_service')
----
ducknng: service not found

statement error
SELECT ducknng_set_service_peer_allowlist('missing_service', '[]')
----
ducknng: service not found

statement error
SELECT ducknng_set_service_ip_allowlist('missing_service', '[]')
----
ducknng: service not found

statement error
SELECT ducknng_set_service_authorizer('missing_service', 'SELECT true AS allow')
----
ducknng: service not found

statement error
SELECT ducknng_set_service_limits('missing_service', 1::UBIGINT)
----
ducknng: service not found

statement error
SELECT ducknng_set_service_limits('missing_service', 1::UBIGINT, 1::UBIGINT)
----
ducknng: service not found

statement error
SELECT ducknng_set_service_limits('missing_service', 1::UBIGINT, 1::UBIGINT, 1::UBIGINT)
----
ducknng: service not found

statement error
SELECT ducknng_open_socket('not-a-protocol')
----
ducknng: protocol must be one of bus, pair, pair0, pair1, poly, push, pull, pub, sub, req, rep, surveyor, respondent

statement error
SELECT ducknng_close_socket(999::UBIGINT)
----
ducknng: client socket not found

statement error
SELECT ducknng_send_socket_raw(999::UBIGINT, from_hex('00'), 10)
----
ducknng: active client socket not found

statement error
SELECT ducknng_recv_socket_raw(999::UBIGINT, 10)
----
ducknng: active client socket not found

query I
SELECT ducknng_request_socket_raw(999::UBIGINT, from_hex('00'), 10) IS NULL
----
true

query IT
SELECT ok, error
FROM ducknng_decode_frame(from_hex('00'))
----
0	ducknng: invalid frame envelope

statement error
SELECT ducknng_drop_tls_config(999::UBIGINT)
----
ducknng: tls config not found

statement error
SELECT ducknng_set_tls_peer_allowlist(999::UBIGINT, '[]')
----
ducknng: tls config not found

statement error
SELECT ducknng_tls_config_from_pem(NULL, NULL, NULL, NULL, 0)
----
ducknng: invalid tls pem arguments

statement error
SELECT ducknng_tls_config_from_files(NULL, NULL, NULL, 0)
----
ducknng: invalid tls config file arguments

statement error
SELECT ducknng_self_signed_tls_config('bad name!', 1, 0)
----
ducknng: common name must use only letters, digits, dot, colon, dash, or underscore

statement error
SELECT ducknng_start_server('bad_ip_json', 'tcp://127.0.0.1:0', 1, 134217728, 300000, 0::UBIGINT, 'not-json')
----
ducknng: IP allowlist must be a JSON array of strings

statement error
SELECT ducknng_start_server('bad_ip_cidr', 'tcp://127.0.0.1:0', 1, 134217728, 300000, 0::UBIGINT, '["127.0.0.1/99"]')
----
ducknng: invalid IPv4 CIDR prefix in IP allowlist

query I
SELECT CASE
  WHEN ducknng_start_server('negative_rpc', 'tcp://127.0.0.1:0', 1, 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

statement error
SELECT ducknng_set_service_ip_allowlist('negative_rpc', '["not-an-ip"]')
----
ducknng: IP allowlist entries must be IPv4/IPv6 literals or CIDR blocks

statement error
SELECT ducknng_set_service_peer_allowlist('negative_rpc', '{"bad":true}')
----
ducknng: peer allowlist must be a JSON array of strings

query I
SELECT CASE WHEN ducknng_set_service_limits('negative_rpc', 0::UBIGINT) THEN 1 ELSE 0 END
----
1

query III
SELECT max_open_sessions, max_active_pipes, max_inflight_requests FROM ducknng_list_servers() WHERE name = 'negative_rpc'
----
0	0	0

statement error
SELECT ducknng_start_server('negative_rpc', 'tcp://127.0.0.1:0', 1, 134217728, 300000, 0::UBIGINT)
----
service already exists

query I
SELECT CASE WHEN ducknng_stop_server('negative_rpc') THEN 1 ELSE 0 END
----
1
