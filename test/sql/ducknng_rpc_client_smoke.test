# name: test/sql/ducknng_rpc_client_smoke.test
# group: [ducknng]

require ducknng

query I
SELECT CASE
  WHEN ducknng_server_start('rpc_smoke', 'ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1, 134217728, 300000, NULL, NULL, NULL)
  THEN 1 ELSE 0 END
----
1

query I
SELECT position('"name":"exec"' IN ducknng_remote_manifest('ipc:///tmp/ducknng_rpc_client_smoke.ipc')) > 0
----
1

query I
SELECT ducknng_remote_exec('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'CREATE TABLE remote_t(i INTEGER)')
----
0

query I
SELECT ducknng_remote_exec('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'INSERT INTO remote_t VALUES (7), (8)')
----
2

query II
SELECT * FROM ducknng_remote('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'SELECT i, i > 7 AS gt_7 FROM remote_t ORDER BY i')
----
7	false
8	true

query I
SELECT ducknng_socket('req')
----
1

query I
SELECT CASE WHEN ducknng_dial(1, 'ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1000) THEN 1 ELSE 0 END
----
1

query ITTII
SELECT socket_id, protocol, url, open, connected
FROM ducknng_sockets()
----
1	req	ipc:///tmp/ducknng_rpc_client_smoke.ipc	true	true

query I
SELECT substr(hex(ducknng_request_socket(1, from_hex('01000000000000000000000000000000000000000000'), 1000)), 1, 28) = '0102040000000800000000000000'
----
1

query I
SELECT substr(hex(ducknng_request('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000)), 1, 28) = '0102040000000800000000000000'
----
1

query I
SELECT CASE WHEN ducknng_close(1) THEN 1 ELSE 0 END
----
1

query I
SELECT CASE WHEN ducknng_server_stop('rpc_smoke') THEN 1 ELSE 0 END
----
1
