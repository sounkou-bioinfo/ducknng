statement ok
CREATE TEMP TABLE rpc_aio_launch AS
SELECT
  ducknng_get_rpc_manifest_raw_aio('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1000, 0::UBIGINT) AS manifest_aio,
  ducknng_run_rpc_raw_aio('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'INSERT INTO remote_t VALUES (9)', 1000, 0::UBIGINT) AS exec_aio

query II
SELECT manifest_aio > 0, exec_aio > manifest_aio
FROM rpc_aio_launch
----
1	1

statement ok
CREATE TEMP TABLE rpc_aio_collect AS
SELECT *
FROM ducknng_aio_collect((SELECT list_value(manifest_aio, exec_aio) FROM rpc_aio_launch), 1000)

