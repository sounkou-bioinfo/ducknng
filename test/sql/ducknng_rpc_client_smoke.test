# name: test/sql/ducknng_rpc_client_smoke.test
# group: [ducknng]

require ducknng

query I
SELECT CASE
  WHEN ducknng_server_start('rpc_smoke', 'ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1, 134217728, 300000, NULL, NULL, NULL)
  THEN 1 ELSE 0 END
----
1

query I
SELECT position('"name":"exec"' IN ducknng_remote_manifest('ipc:///tmp/ducknng_rpc_client_smoke.ipc')) > 0
----
1

query I
SELECT ducknng_remote_exec('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'CREATE TABLE remote_t(i INTEGER)')
----
0

query I
SELECT ducknng_remote_exec('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'INSERT INTO remote_t VALUES (7), (8)')
----
2

query I
SELECT CASE WHEN ducknng_server_stop('rpc_smoke') THEN 1 ELSE 0 END
----
1
