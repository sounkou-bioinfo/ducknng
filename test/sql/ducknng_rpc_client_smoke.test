# name: test/sql/ducknng_rpc_client_smoke.test
# group: [ducknng]

require ducknng

query I
SELECT CASE
  WHEN ducknng_start_server('rpc_smoke', 'ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1, 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

query II
SELECT ok, position('"name":"exec"' IN manifest) > 0
FROM ducknng_get_rpc_manifest('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 0::UBIGINT)
----
1	0

query I
SELECT ducknng_register_exec_method()
----
1

query TI
SELECT name, requires_auth
FROM ducknng_list_methods()
WHERE name = 'exec'
----
exec	false

query II
SELECT ok, position('"name":"exec"' IN manifest) > 0
FROM ducknng_get_rpc_manifest('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 0::UBIGINT)
----
1	1

query IIIIIII
SELECT ok, version, type, flags, type_name, name, position('"name":"exec"' IN payload_text) > 0
FROM ducknng_decode_frame(ducknng_get_rpc_manifest_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 0::UBIGINT))
----
1	1	2	4	result	manifest	1

query III
SELECT ok, type_name, name
FROM ducknng_decode_frame(ducknng_run_rpc_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'DROP TABLE IF EXISTS remote_t', 0::UBIGINT))
----
1	result	exec

query IIII
SELECT ok, rows_changed, statement_type, result_type
FROM ducknng_run_rpc('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'CREATE TABLE IF NOT EXISTS remote_t(i INTEGER)', 0::UBIGINT)
----
1	0	7	2

query IIII
SELECT ok, rows_changed, statement_type, result_type
FROM ducknng_run_rpc('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'DELETE FROM remote_t', 0::UBIGINT)
----
1	0	5	1

query III
SELECT ok, type_name, name
FROM ducknng_decode_frame(ducknng_run_rpc_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'INSERT INTO remote_t VALUES (7), (8)', 0::UBIGINT))
----
1	result	exec

query II
SELECT * FROM ducknng_query_rpc('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'SELECT DISTINCT i, i > 7 AS gt_7 FROM remote_t WHERE i IN (7, 8) ORDER BY i', 0::UBIGINT)
----
7	false
8	true

query IITT
SELECT ok, session_id, state, next_method
FROM ducknng_open_query('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'SELECT i FROM remote_t ORDER BY i', 0::UBIGINT, 0::UBIGINT, 0::UBIGINT)
----
1	1	open	fetch

query I
SELECT sessions
FROM ducknng_list_servers()
WHERE name = 'rpc_smoke'
----
1

query IIIII
SELECT ok, session_id, state IS NULL, octet_length(payload) > 0, end_of_stream
FROM ducknng_fetch_query('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1::UBIGINT, 0::UBIGINT, 0::UBIGINT, 0::UBIGINT)
----
1	1	1	1	0

query IITII
SELECT ok, session_id, state, payload IS NULL, end_of_stream
FROM ducknng_fetch_query('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1::UBIGINT, 0::UBIGINT, 0::UBIGINT, 0::UBIGINT)
----
1	1	exhausted	1	1

query IIT
SELECT ok, session_id, state
FROM ducknng_close_query('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1::UBIGINT, 0::UBIGINT)
----
1	1	closed

query I
SELECT sessions
FROM ducknng_list_servers()
WHERE name = 'rpc_smoke'
----
0

query IITT
SELECT ok, session_id, state, next_method
FROM ducknng_open_query('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'SELECT i FROM remote_t ORDER BY i', 0::UBIGINT, 0::UBIGINT, 0::UBIGINT)
----
1	2	open	fetch

query IIT
SELECT ok, session_id, state
FROM ducknng_cancel_query('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 2::UBIGINT, 0::UBIGINT)
----
1	2	cancelled

query I
SELECT sessions
FROM ducknng_list_servers()
WHERE name = 'rpc_smoke'
----
0

query I
SELECT ducknng_open_socket('req')
----
1

query I
SELECT CASE WHEN ducknng_dial_socket(1, 'ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1000) THEN 1 ELSE 0 END
----
1

query ITTII
SELECT socket_id, protocol, url, open, connected
FROM ducknng_list_sockets()
----
1	req	ipc:///tmp/ducknng_rpc_client_smoke.ipc	true	true

query I
SELECT substr(hex(ducknng_request_socket_raw(1, from_hex('01000000000000000000000000000000000000000000'), 1000)), 1, 28) = '0102040000000800000000000000'
----
1

query II
SELECT ok, substr(hex(payload), 1, 28) = '0102040000000800000000000000'
FROM ducknng_request_socket(1::UBIGINT, from_hex('01000000000000000000000000000000000000000000'), 1000)
----
1	1

query I
SELECT substr(hex(ducknng_request_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000, 0::UBIGINT)), 1, 28) = '0102040000000800000000000000'
----
1

query II
SELECT ok, substr(hex(payload), 1, 28) = '0102040000000800000000000000'
FROM ducknng_request('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000, 0::UBIGINT)
----
1	1

query IIIIIII
SELECT ok, version, type, flags, type_name, name, position('"name":"exec"' IN payload_text) > 0
FROM ducknng_decode_frame(ducknng_request_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000, 0::UBIGINT))
----
1	1	2	4	result	manifest	1

statement ok
CREATE TEMP TABLE aio_launch AS
SELECT
  ducknng_request_raw_aio('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000, 0::UBIGINT) AS aio1,
  ducknng_request_raw_aio('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000, 0::UBIGINT) AS aio2

query II
SELECT aio1 > 0, aio2 > aio1
FROM aio_launch
----
1	1

query III
SELECT aio_id IN (SELECT aio1 FROM aio_launch) OR aio_id IN (SELECT aio2 FROM aio_launch), ok, octet_length(frame) > 0
FROM ducknng_aio_collect((SELECT list_value(aio1, aio2) FROM aio_launch), 1000)
ORDER BY aio_id
----
1	1	1
1	1	1

query II
SELECT ducknng_aio_ready(aio1), ducknng_aio_ready(aio2)
FROM aio_launch
----
1	1

query I
SELECT COUNT(*)
FROM ducknng_aio_collect((SELECT list_value(aio1, aio2) FROM aio_launch), 0)
----
0

query I
SELECT ducknng_aio_drop(aio1) AND ducknng_aio_drop(aio2)
FROM aio_launch
----
1

query II
SELECT ducknng_aio_ready(aio1), ducknng_aio_drop(aio1)
FROM aio_launch
----
0	0

statement ok
DROP TABLE aio_launch

statement ok
CREATE TEMP TABLE rpc_aio_launch AS
SELECT
  ducknng_get_rpc_manifest_raw_aio('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1000, 0::UBIGINT) AS manifest_aio,
  ducknng_run_rpc_raw_aio('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'INSERT INTO remote_t VALUES (9)', 1000, 0::UBIGINT) AS exec_aio

query II
SELECT manifest_aio > 0, exec_aio > manifest_aio
FROM rpc_aio_launch
----
1	1

statement ok
CREATE TEMP TABLE rpc_aio_collect AS
SELECT *
FROM ducknng_aio_collect((SELECT list_value(manifest_aio, exec_aio) FROM rpc_aio_launch), 1000)

query I
SELECT COUNT(*)
FROM rpc_aio_collect
----
2

query II
SELECT ok, hex(frame) = hex(ducknng_get_rpc_manifest_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 0::UBIGINT))
FROM rpc_aio_collect
WHERE aio_id = (SELECT manifest_aio FROM rpc_aio_launch)
----
1	1

query II
SELECT ok, hex(frame) = hex(ducknng_run_rpc_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'INSERT INTO remote_t VALUES (9)', 0::UBIGINT))
FROM rpc_aio_collect
WHERE aio_id = (SELECT exec_aio FROM rpc_aio_launch)
----
1	1

query I
SELECT ducknng_aio_drop(manifest_aio) AND ducknng_aio_drop(exec_aio)
FROM rpc_aio_launch
----
1

statement ok
DROP TABLE rpc_aio_collect

statement ok
DROP TABLE rpc_aio_launch

query II
SELECT * FROM ducknng_query_rpc('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'SELECT DISTINCT i, i > 8 AS gt_8 FROM remote_t WHERE i IN (7, 8, 9) ORDER BY i', 0::UBIGINT)
----
7	false
8	false
9	true

statement ok
CREATE TEMP TABLE aio_socket_launch AS
SELECT ducknng_request_socket_raw_aio(1::UBIGINT, from_hex('01000000000000000000000000000000000000000000'), 1000) AS aio1

query I
SELECT aio1 > 0
FROM aio_socket_launch
----
1

query III
SELECT aio_id = (SELECT aio1 FROM aio_socket_launch), ok, octet_length(frame) > 0
FROM ducknng_aio_collect((SELECT list_value(aio1) FROM aio_socket_launch), 1000)
----
1	1	1

query I
SELECT ducknng_aio_drop(aio1)
FROM aio_socket_launch
----
1

statement ok
DROP TABLE aio_socket_launch

query III
SELECT ducknng_aio_ready(999::UBIGINT), ducknng_aio_cancel(999::UBIGINT), ducknng_aio_drop(999::UBIGINT)
----
0	0	0

