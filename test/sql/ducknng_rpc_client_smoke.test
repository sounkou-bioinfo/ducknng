# name: test/sql/ducknng_rpc_client_smoke.test
# group: [ducknng]

require ducknng

query I
SELECT CASE
  WHEN ducknng_start_server('rpc_smoke', 'ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1, 134217728, 300000, NULL, NULL, NULL)
  THEN 1 ELSE 0 END
----
1

query II
SELECT ok, position('"name":"exec"' IN manifest) > 0
FROM ducknng_get_rpc_manifest('ipc:///tmp/ducknng_rpc_client_smoke.ipc')
----
1	1

query IIIIIII
SELECT ok, version, type, flags, type_name, name, position('"name":"exec"' IN payload_text) > 0
FROM ducknng_decode_frame(ducknng_get_rpc_manifest_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc'))
----
1	1	2	4	result	manifest	1

query III
SELECT ok, type_name, name
FROM ducknng_decode_frame(ducknng_run_rpc_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'DROP TABLE IF EXISTS remote_t'))
----
1	result	exec

query IIII
SELECT ok, rows_changed, statement_type, result_type
FROM ducknng_run_rpc('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'CREATE TABLE IF NOT EXISTS remote_t(i INTEGER)')
----
1	0	7	2

query IIII
SELECT ok, rows_changed, statement_type, result_type
FROM ducknng_run_rpc('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'DELETE FROM remote_t')
----
1	0	5	1

query III
SELECT ok, type_name, name
FROM ducknng_decode_frame(ducknng_run_rpc_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'INSERT INTO remote_t VALUES (7), (8)'))
----
1	result	exec

query II
SELECT * FROM ducknng_query_rpc('ipc:///tmp/ducknng_rpc_client_smoke.ipc', 'SELECT DISTINCT i, i > 7 AS gt_7 FROM remote_t WHERE i IN (7, 8) ORDER BY i')
----
7	false
8	true

query I
SELECT ducknng_open_socket('req')
----
1

query I
SELECT CASE WHEN ducknng_dial_socket(1, 'ipc:///tmp/ducknng_rpc_client_smoke.ipc', 1000) THEN 1 ELSE 0 END
----
1

query ITTII
SELECT socket_id, protocol, url, open, connected
FROM ducknng_list_sockets()
----
1	req	ipc:///tmp/ducknng_rpc_client_smoke.ipc	true	true

query I
SELECT substr(hex(ducknng_request_socket_raw(1, from_hex('01000000000000000000000000000000000000000000'), 1000)), 1, 28) = '0102040000000800000000000000'
----
1

query II
SELECT ok, substr(hex(payload), 1, 28) = '0102040000000800000000000000'
FROM ducknng_request_socket(1::UBIGINT, from_hex('01000000000000000000000000000000000000000000'), 1000)
----
1	1

query I
SELECT substr(hex(ducknng_request_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000)), 1, 28) = '0102040000000800000000000000'
----
1

query II
SELECT ok, substr(hex(payload), 1, 28) = '0102040000000800000000000000'
FROM ducknng_request('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000)
----
1	1

query IIIIIII
SELECT ok, version, type, flags, type_name, name, position('"name":"exec"' IN payload_text) > 0
FROM ducknng_decode_frame(ducknng_request_raw('ipc:///tmp/ducknng_rpc_client_smoke.ipc', from_hex('01000000000000000000000000000000000000000000'), 1000))
----
1	1	2	4	result	manifest	1

query II
SELECT ok, error = 'ducknng: request URL must not be NULL or empty'
FROM ducknng_request('', from_hex('01000000000000000000000000000000000000000000'), 1000)
----
0	1

query I
SELECT CASE WHEN ducknng_close_socket(1) THEN 1 ELSE 0 END
----
1

query I
SELECT CASE WHEN ducknng_stop_server('rpc_smoke') THEN 1 ELSE 0 END
----
1
