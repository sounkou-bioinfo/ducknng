query I
SELECT ducknng_drop_tls_config(getvariable('mtls_tls_config_id')::UBIGINT)
----
1

query I
SELECT ducknng_tls_config_from_files('test/certs/mtls/server-cert-key.pem', 'test/certs/mtls/ca.pem', NULL, 2) > 0
----
1

statement ok
SET VARIABLE mtls_server_config_id = (
  SELECT max(tls_config_id) FROM ducknng_list_tls_configs()
)

query I
