# name: test/sql/ducknng_mtls_auth.test
# group: [ducknng]

require ducknng

query I
SELECT ducknng_self_signed_tls_config('127.0.0.1', 365, 2) > 0
----
1

statement ok
SET VARIABLE mtls_tls_config_id = (
  SELECT max(tls_config_id) FROM ducknng_list_tls_configs()
)

query I
SELECT CASE
  WHEN ducknng_start_server(
    'mtls_rpc',
    'tls+tcp://127.0.0.1:0',
    1,
    134217728,
    300000,
    getvariable('mtls_tls_config_id')::UBIGINT
  )
  THEN 1 ELSE 0 END
----
1

statement ok
SET VARIABLE mtls_rpc_url = (
  SELECT listen FROM ducknng_list_servers() WHERE name = 'mtls_rpc'
)

query III
SELECT tls_enabled, tls_auth_mode, peer_identity_required
FROM ducknng_list_servers()
WHERE name = 'mtls_rpc'
----
true	2	true

query IIIII
SELECT ok, type_name, name,
       position('"session_token"' IN payload_text) > 0,
       position('"peer_identity_required":true' IN payload_text) > 0
FROM ducknng_decode_frame(
  ducknng_request_raw(
    getvariable('mtls_rpc_url')::VARCHAR,
    from_hex('01000000000000000000000000000000000000000000'),
    2000,
    getvariable('mtls_tls_config_id')::UBIGINT
  )
)
----
1	result	manifest	1	1

statement ok
CREATE TEMP TABLE mtls_open AS
SELECT *
FROM ducknng_open_query(
  getvariable('mtls_rpc_url')::VARCHAR,
  'SELECT 42 AS answer',
  0::UBIGINT,
  0::UBIGINT,
  getvariable('mtls_tls_config_id')::UBIGINT
)

statement ok
SET VARIABLE mtls_session_token = (
  SELECT session_token FROM mtls_open
)

query IIITT
SELECT ok, session_id, length(session_token) = 32, state, next_method
FROM mtls_open
----
1	1	1	open	fetch

query IIIII
SELECT ok, session_id, state IS NULL, octet_length(payload) > 0, end_of_stream
FROM ducknng_fetch_query(
  getvariable('mtls_rpc_url')::VARCHAR,
  1::UBIGINT,
  getvariable('mtls_session_token')::VARCHAR,
  0::UBIGINT,
  0::UBIGINT,
  getvariable('mtls_tls_config_id')::UBIGINT
)
----
1	1	1	1	0

query IIT
SELECT ok, session_id, state
FROM ducknng_close_query(
  getvariable('mtls_rpc_url')::VARCHAR,
  1::UBIGINT,
  getvariable('mtls_session_token')::VARCHAR,
  getvariable('mtls_tls_config_id')::UBIGINT
)
----
1	1	closed

statement ok
DROP TABLE mtls_open

query I
SELECT CASE WHEN ducknng_stop_server('mtls_rpc') THEN 1 ELSE 0 END
----
1

query I
SELECT CASE
  WHEN ducknng_start_http_server(
    'mtls_http',
    'https://127.0.0.1:0/_ducknng',
    134217728,
    300000,
    getvariable('mtls_tls_config_id')::UBIGINT
  )
  THEN 1 ELSE 0 END
----
1

statement ok
SET VARIABLE mtls_http_url = (
  SELECT listen FROM ducknng_list_servers() WHERE name = 'mtls_http'
)

query III
SELECT tls_enabled, tls_auth_mode, peer_identity_required
FROM ducknng_list_servers()
WHERE name = 'mtls_http'
----
true	2	true

query IIIII
