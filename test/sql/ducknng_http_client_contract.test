# name: test/sql/ducknng_http_client_contract.test
# group: [ducknng]

require ducknng

query III
SELECT ok, status IS NULL, error = 'ducknng: http:// or https:// URL is required'
FROM ducknng_ncurl('ipc:///tmp/nope', NULL, NULL, NULL, 1000, 0::UBIGINT)
----
0	1	1

query III
SELECT ok, status IS NULL, error = 'ducknng: headers_json must be a JSON array of {name,value} objects'
FROM ducknng_ncurl('http://127.0.0.1:1/', 'GET', '{}', NULL, 1000, 0::UBIGINT)
----
0	1	1

statement ok
CREATE TEMP TABLE ncurl_bad_aio AS
SELECT ducknng_ncurl_aio('http://127.0.0.1:1/', 'GET', NULL, NULL, 100, 0::UBIGINT) AS aio

query I
SELECT aio > 0
FROM ncurl_bad_aio
----
1

query I
SELECT COUNT(*)
FROM ducknng_aio_collect((SELECT list_value(aio) FROM ncurl_bad_aio), 0)
----
0

query I
SELECT ducknng_aio_drop(aio)
FROM ncurl_bad_aio
----
1

statement ok
DROP TABLE ncurl_bad_aio
