# name: test/sql/ducknng_socket_protocols.test
# group: [ducknng]

require ducknng

query I
SELECT ducknng_open_socket('pair')
----
1

query I
SELECT ducknng_listen_socket(1, 'ipc:///tmp/ducknng_socket_protocols_pair.ipc', 134217728, 0::UBIGINT)
----
1

query I
SELECT ducknng_open_socket('pair')
----
2

query I
SELECT ducknng_dial_socket(2, 'ipc:///tmp/ducknng_socket_protocols_pair.ipc', 1000)
----
1

query ITTIII
SELECT socket_id, protocol, url, open, connected, listening
FROM ducknng_list_sockets()
ORDER BY socket_id
----
1	pair	ipc:///tmp/ducknng_socket_protocols_pair.ipc	true	false	true
2	pair	ipc:///tmp/ducknng_socket_protocols_pair.ipc	true	true	false

statement ok
CREATE TEMP TABLE recv_launch AS
SELECT ducknng_recv_socket_raw_aio(1::UBIGINT, 1000) AS recv_aio

statement ok
CREATE TEMP TABLE send_launch AS
SELECT ducknng_send_socket_raw_aio(2::UBIGINT, from_hex('6173796e632072657175657374'), 1000) AS send_aio

query I
SELECT recv_aio > 0 FROM recv_launch
----
1

query I
SELECT send_aio > 0 FROM send_launch
----
1

query III
SELECT aio_id = (SELECT send_aio FROM send_launch), ok, frame IS NULL
FROM ducknng_aio_collect((SELECT list_value(send_aio) FROM send_launch), 1000)
----
1	1	1

query III
SELECT aio_id = (SELECT recv_aio FROM recv_launch), ok, hex(frame) = '6173796E632072657175657374'
FROM ducknng_aio_collect((SELECT list_value(recv_aio) FROM recv_launch), 1000)
----
1	1	1

query IIIIIIII
SELECT kind = 'send', state = 'collected', phase = 'send', send_done, send_ok, recv_done = false, recv_ok IS NULL, has_reply_frame = false
FROM ducknng_aio_status((SELECT send_aio FROM send_launch))
----
1	1	1	1	1	1	1	1

query IIIIIIII
SELECT kind = 'recv', state = 'collected', phase = 'recv', send_done = false, send_ok IS NULL, recv_done, recv_ok, has_reply_frame
FROM ducknng_aio_status((SELECT recv_aio FROM recv_launch))
----
1	1	1	1	1	1	1	1

query III
SELECT exists, terminal, state IS NULL
FROM ducknng_aio_status(999::UBIGINT)
----
0	0	1

statement ok
DROP TABLE send_launch

statement ok
DROP TABLE recv_launch

query I
SELECT ducknng_close_socket(2)
----
1

query I
SELECT ducknng_close_socket(1)
----
1

query I
SELECT ducknng_open_socket('pull')
----
3

query I
SELECT ducknng_listen_socket(3, 'ipc:///tmp/ducknng_socket_protocols_pushpull.ipc', 134217728, 0::UBIGINT)
----
1

query I
SELECT ducknng_open_socket('push')
----
4

query I
SELECT ducknng_dial_socket(4, 'ipc:///tmp/ducknng_socket_protocols_pushpull.ipc', 1000)
----
1

statement ok
CREATE TEMP TABLE pushpull_recv AS
SELECT ducknng_recv_socket_raw_aio(3::UBIGINT, 1000) AS recv_aio

query I
SELECT ducknng_send_socket_raw(4::UBIGINT, from_hex('707573682d70756c6c'), 1000)
----
1

query II
SELECT ok, hex(frame) = '707573682D70756C6C'
FROM ducknng_aio_collect((SELECT list_value(recv_aio) FROM pushpull_recv), 1000)
----
1	1

query I
SELECT ducknng_aio_drop((SELECT recv_aio FROM pushpull_recv))
----
1

statement ok
DROP TABLE pushpull_recv

