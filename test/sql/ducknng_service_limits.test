# name: test/sql/ducknng_service_limits.test
# group: [ducknng]

require ducknng

query I
SELECT CASE
  WHEN ducknng_start_server('limit_rpc', 'tcp://127.0.0.1:0', 1, 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

statement ok
SET VARIABLE limit_rpc_url = (
  SELECT listen FROM ducknng_list_servers() WHERE name = 'limit_rpc'
)

query I
SELECT CASE WHEN ducknng_set_service_limits('limit_rpc', 1::UBIGINT) THEN 1 ELSE 0 END
----
1

query I
SELECT max_open_sessions FROM ducknng_list_servers() WHERE name = 'limit_rpc'
----
1

statement ok
CREATE TEMP TABLE limit_open AS
SELECT session_id, session_token
FROM ducknng_open_query(getvariable('limit_rpc_url')::VARCHAR, 'SELECT 11 AS x', 0::UBIGINT, 0::UBIGINT, 0::UBIGINT)
WHERE ok = true

query I
SELECT count(*) FROM limit_open
----
1

query II
SELECT ok, error LIKE '%max open sessions exceeded%'
FROM ducknng_open_query(getvariable('limit_rpc_url')::VARCHAR, 'SELECT 12 AS x', 0::UBIGINT, 0::UBIGINT, 0::UBIGINT)
----
0	1

statement ok
SET VARIABLE limit_session_id = (SELECT session_id FROM limit_open)

statement ok
SET VARIABLE limit_session_token = (SELECT session_token FROM limit_open)

query I
SELECT ok
FROM ducknng_close_query(
  getvariable('limit_rpc_url')::VARCHAR,
  getvariable('limit_session_id')::UBIGINT,
  getvariable('limit_session_token')::VARCHAR,
  0::UBIGINT
)
----
1

query I
SELECT ok
FROM ducknng_open_query(getvariable('limit_rpc_url')::VARCHAR, 'SELECT 13 AS x', 0::UBIGINT, 0::UBIGINT, 0::UBIGINT)
----
1

query I
SELECT CASE WHEN ducknng_stop_server('limit_rpc') THEN 1 ELSE 0 END
----
1
