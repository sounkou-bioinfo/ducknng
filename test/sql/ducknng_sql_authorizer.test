# name: test/sql/ducknng_sql_authorizer.test
# group: [ducknng]

require ducknng

query I
SELECT count(*) FROM ducknng_auth_context()
----
0

query I
SELECT CASE
  WHEN ducknng_start_server('auth_rpc', 'tcp://127.0.0.1:0', 1, 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

statement ok
SET VARIABLE auth_rpc_url = (
  SELECT listen FROM ducknng_list_servers() WHERE name = 'auth_rpc'
)

query I
SELECT CASE WHEN ducknng_set_service_authorizer(
  'auth_rpc',
  'SELECT false AS allow, 403 AS status, ''sql callback denied'' AS reason FROM ducknng_auth_context()'
) THEN 1 ELSE 0 END
----
1

query I
SELECT sql_authorizer_active FROM ducknng_list_servers() WHERE name = 'auth_rpc'
----
true

query II
SELECT ok, error LIKE '%sql callback denied%'
FROM ducknng_get_rpc_manifest(getvariable('auth_rpc_url')::VARCHAR, 0::UBIGINT)
----
0	1

query I
SELECT CASE WHEN ducknng_set_service_authorizer(
  'auth_rpc',
  'SELECT transport_family = ''nng'' AND scheme = ''tcp'' AND rpc_method = ''manifest'' AND remote_ip = ''127.0.0.1'' AS allow, 403 AS status, ''unexpected auth context'' AS reason FROM ducknng_auth_context()'
) THEN 1 ELSE 0 END
----
1

query II
SELECT ok,
       json_extract(manifest::JSON, '$.server.security.sql_authorizer_active')::BOOLEAN
FROM ducknng_get_rpc_manifest(getvariable('auth_rpc_url')::VARCHAR, 0::UBIGINT)
----
1	true

query I
SELECT CASE WHEN ducknng_set_service_authorizer('auth_rpc', NULL) THEN 1 ELSE 0 END
----
1

query I
SELECT sql_authorizer_active FROM ducknng_list_servers() WHERE name = 'auth_rpc'
----
false

query I
SELECT CASE WHEN ducknng_stop_server('auth_rpc') THEN 1 ELSE 0 END
----
1

query I
SELECT CASE
  WHEN ducknng_start_http_server('auth_http', 'http://127.0.0.1:45465/_ducknng', 134217728, 300000, 0::UBIGINT)
  THEN 1 ELSE 0 END
----
1

query I
SELECT CASE WHEN ducknng_set_service_authorizer(
  'auth_http',
  'SELECT transport_family = ''http'' AND scheme = ''http'' AND http_method = ''POST'' AND http_path = ''/_ducknng'' AND rpc_method = ''manifest'' AS allow, 403 AS status, ''http callback denied'' AS reason FROM ducknng_auth_context()'
) THEN 1 ELSE 0 END
----
1

query I
SELECT ok
FROM ducknng_get_rpc_manifest('http://127.0.0.1:45465/_ducknng', 0::UBIGINT)
----
1

query I
SELECT CASE WHEN ducknng_set_service_authorizer(
  'auth_http',
  'SELECT false AS allow, 403 AS status, ''http callback denied'' AS reason FROM ducknng_auth_context()'
) THEN 1 ELSE 0 END
----
1

query II
SELECT ok, error LIKE '%403%'
FROM ducknng_get_rpc_manifest('http://127.0.0.1:45465/_ducknng', 0::UBIGINT)
----
0	1

query I
SELECT CASE WHEN ducknng_stop_server('auth_http') THEN 1 ELSE 0 END
----
1
